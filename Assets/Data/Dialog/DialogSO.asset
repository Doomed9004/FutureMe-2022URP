%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d5905cbd71dd1694bba9c888886f175e, type: 3}
  m_Name: DialogSO
  m_EditorClassIdentifier: 
  dialogs:
  - texts:
    - "\u55EF\u2026\u2026"
    - "\u4E0A\u5B66\u8981\u8FDF\u5230\u4E86"
    - "\u7B49\u7B49\uFF01\u8FD9\uFF0C\u8FD9\u662F\u6211\u7684\u623F\u95F4\u5417\u2026\u2026"
    - "\u7535\u8111\u3001\u624B\u673A\u3001\u5409\u4ED6\u2026\u2026"
    - "\u96BE\u9053\u6211\u7A7F\u8D8A\u5230\u672A\u6765\u4E86\uFF1F"
    sceneName: "\u4E3B\u573A\u666F23"
    scene: {fileID: 0}
  - texts:
    - "\u201D\u6211\u201C\u771F\u7684\u5B66\u4E86\u5409\u4ED6\uFF01"
    - "\u4F46\u662F\u8FD9\u91CC\u597D\u50CF\u7F3A\u4E86\u6839\u5F26\u2026\u2026"
    sceneName: "\u5409\u4ED6"
    scene: {fileID: 0}
  - texts:
    - "\u8FD9\u91CC\u5E94\u8BE5\u662F\u6211\u4ECE\u5C0F\u5230\u5927\u7684\u7167\u7247\uFF0C\u597D\u50CF\u7F3A\u4E86\u51E0\u5F20\u2026\u2026"
    sceneName: "\u7167\u7247\u5899"
    scene: {fileID: 0}
  - texts:
    - "\u600E\u4E48\u624D\u4E09\u70B9\uFF0C\u6211\u662F\u5728\u68A6\u91CC\u5417\u2026\u2026"
    - "\u8FD9\u4E0D\u662F\u90BB\u5C45\u9001\u7684\u73A9\u5076\u5417\uFF1F"
    - "\u55EF\uFF1F\u73A9\u5076\u4E0B\u9762\u597D\u50CF\u6709\u4E1C\u897F"
    sceneName: "\u5E8A\u5934\u67DC"
    scene: {fileID: 0}
  - texts:
    - "\u660E\u660E\u72B6\u6001\u4E0D\u597D\uFF0C\u4E3A\u4EC0\u4E48\u7792\u7740\u4E0D\u8BF4\u5462\uFF1F"
    sceneName: "\u624B\u673A"
    scene: {fileID: 0}
  - texts:
    - "\u8FD8\u597D\u6211\u6709\u5199\u65E5\u8BB0\u7684\u4E60\u60EF\uFF0C\u4F46\u662F\u8FD9\u4E00\u9875\u600E\u4E48\u88AB\u6495\u6389\u4E86\uFF1F"
    sceneName: "\u65E5\u8BB0"
    scene: {fileID: 0}
  - texts:
    - "\u770B\u6765\u91CC\u9762\u7684\u4E1C\u897F\u5F88\u91CD\u8981\uFF0C\u4E0D\u8FC7\u5BC6\u7801\u662F\u4EC0\u4E48\u5462\uFF1F"
    - "\u4E5F\u8BB8\u548C\u97F3\u4E50\u6709\u5173"
    sceneName: "\u5BC6\u7801\u7BB1"
    scene: {fileID: 0}
  - texts:
    - "\u5783\u573E\u6876\u91CC\u9762\u6709\u836F\u74F6\u3001\u7434\u5F26\u3001\u7167\u7247\u2026\u2026"
    - "\uFF01\uFF01\uFF01\u4E3A\u4EC0\u4E48\u7434\u5F26\u548C\u7167\u7247\u5728\u5783\u573E\u6876\u91CC\u554A\uFF01\uFF01\uFF01"
    sceneName: "\u5783\u573E\u6876"
    scene: {fileID: 0}
  - texts:
    - "\u5929\u4EAE\u4E86\u5417\uFF0C\u521A\u624D\u53D1\u751F\u7684\u2026\u2026"
    - "\u662F\u68A6\u5417\uFF1F"
    - "\u5BF9\u4E86\uFF0C\u770B\u770B\u65E5\u8BB0"
    sceneName: "\u7ED3\u675F\u573A\u666F"
    scene: {fileID: 0}
  - texts:
    - "\u5DF2\u7ECF\u5F88\u665A\u4E86"
    - "\u65E9\u70B9\u7761\u5427,\u660E\u5929\u8FD8\u8981\u4E0A\u5B66"
    sceneName: "\u4E3B\u573A\u666F12"
    scene: {fileID: 0}
